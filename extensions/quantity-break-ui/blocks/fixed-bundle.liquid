<div
  id="fixed-bundle-root"
  data-product-id="{{ product.id }}"
  data-shop="{{ shop.permanent_domain }}"
  style="margin: 16px 0; display: none;"
></div>

<script>
(function () {
  var root = document.getElementById('fixed-bundle-root');
  if (!root) return;

  var productId = root.dataset.productId;
  var shop      = root.dataset.shop;
  if (!productId || !shop) return;

  function mountWidget() {
    var form = document.querySelector('form[action*="/cart/add"]');
    if (!form) return;

    var qtyWrap =
      form.querySelector('quantity-input') ||
      form.querySelector('[class*="quantity"]') ||
      (form.querySelector('input[name="quantity"]') &&
        form.querySelector('input[name="quantity"]').parentElement);

    if (qtyWrap) {
      qtyWrap.after(root);
    } else {
      form.prepend(root);
    }

    fetchAndRender();
  }

  function fetchAndRender() {
    var apiUrl =
      '/apps/quantity-break?type=fixed-bundle&productId=' +
        encodeURIComponent(productId) +
        '&shop=' +
        encodeURIComponent(shop);

    fetch(apiUrl)
      .then(function (res) { return res.json(); })
      .then(function (data) {
        if (!data.offers || !data.offers.length) return;

        root.innerHTML = ''; // Clear securely

        var headerEl = document.createElement('div');
        headerEl.style.cssText = 'font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#6b7280;margin-bottom:10px;';
        headerEl.textContent = 'Bundle Offers';
        root.appendChild(headerEl);

        data.offers.forEach(function (offer) {
          var pct = offer.offerPercentage;
          var products = offer.products || [];
          var minQty = offer.minQuantity;
          var isMinQtyEnabled = offer.isMinQuantityEnabled;

          var card = document.createElement('div');
          card.style.cssText = 'border:1.5px solid #e5e7eb;border-radius:10px;padding:14px 16px;margin-bottom:8px;background:#fff;';

          var cardHeader = document.createElement('div');
          cardHeader.style.cssText = 'display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;';

          var titleEl = document.createElement('div');
          titleEl.style.cssText = 'font-size:14px;font-weight:600;color:#111827;';
          titleEl.textContent = offer.title;
          cardHeader.appendChild(titleEl);

          if (pct) {
            var badgeEl = document.createElement('div');
            badgeEl.style.cssText = 'background:#dcfce7;color:#15803d;font-size:12px;font-weight:700;padding:4px 10px;border-radius:20px;white-space:nowrap;';
            badgeEl.textContent = pct + '% OFF';
            cardHeader.appendChild(badgeEl);
          }
          card.appendChild(cardHeader);

          var thumbsRow = document.createElement('div');
          thumbsRow.style.cssText = 'display:flex;align-items:flex-start;gap:8px;margin-bottom:10px;flex-wrap:wrap;';

          var productTitles = [];

          products.forEach(function(p, idx) {
            productTitles.push(p.title);

            var thumbWrap = document.createElement('div');
            thumbWrap.style.cssText = 'display:flex;flex-direction:column;align-items:center;gap:4px;';

            if (p.imageUrl) {
              var img = document.createElement('img');
              img.src = p.imageUrl;
              img.width = 48;
              img.height = 48;
              img.style.cssText = 'border-radius:6px;object-fit:cover;border:1px solid #e5e7eb;';
              img.alt = p.title;
              thumbWrap.appendChild(img);
            } else {
              var placeholder = document.createElement('div');
              placeholder.style.cssText = 'width:48px;height:48px;border-radius:6px;background:#f3f4f6;border:1px solid #e5e7eb;';
              thumbWrap.appendChild(placeholder);
            }

            var pName = document.createElement('span');
            pName.style.cssText = 'font-size:11px;color:#6b7280;max-width:56px;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;';
            pName.textContent = p.title;
            thumbWrap.appendChild(pName);

            thumbsRow.appendChild(thumbWrap);

            if (idx < products.length - 1) {
              var plus = document.createElement('span');
              plus.style.cssText = 'font-size:18px;color:#9ca3af;align-self:flex-start;margin-top:12px;';
              plus.textContent = '+';
              thumbsRow.appendChild(plus);
            }
          });

          card.appendChild(thumbsRow);

          var comboText = document.createElement('div');
          comboText.style.cssText = 'font-size:13px;color:#374151;margin-bottom:4px;line-height:1.4;';
          
          var text1 = document.createTextNode('Combine ');
          var strong1 = document.createElement('strong');
          strong1.textContent = productTitles.join(' + ');
          var text2 = document.createTextNode(' and get ');
          var strong2 = document.createElement('strong');
          strong2.textContent = pct + '% off';
          var text3 = document.createTextNode('!');

          comboText.appendChild(text1);
          comboText.appendChild(strong1);
          comboText.appendChild(text2);
          comboText.appendChild(strong2);
          comboText.appendChild(text3);
          
          card.appendChild(comboText);
          root.appendChild(card);
        });

        root.style.display = 'block';
      })
      .catch(function (err) {
        console.error('Error fetching fixed bundles', err);
      });
  }

  function boot() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', mountWidget);
    } else {
      mountWidget();
    }

    var observer = new MutationObserver(function () {
      if (document.querySelector('form[action*="/cart/add"]')) {
        observer.disconnect();
        mountWidget();
      }
    });
    observer.observe(document.body, { childList: true, subtree: true });
  }

  boot();
})();
</script>

{% schema %}
{
  "name": "Fixed Bundle Offers",
  "target": "body",
  "settings": []
}
{% endschema %}