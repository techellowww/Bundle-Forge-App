<div id="bxgy-root" data-product-id="{{ product.id }}" style="margin:16px 0;display:none;"></div>

<script>
(function () {
  var root = document.getElementById('bxgy-root');
  console.log('[BXGY] root found?', !!root);
  if (!root) return;

  var productId = root.dataset.productId;
  console.log('[BXGY] productId:', productId);
  if (!productId) return;

  var isProcessing = false;
  var currentOffer = null;
  var debounceTimer = null;

  var CART_SECTIONS = [
    'cart-drawer',
    'cart-icon-bubble',
    'main-cart-items',
    'cart-notification'
  ];

  function normalizeId(id) {
    if (!id) return null;
    var match = String(id).match(/(\d+)$/);
    return (match && match[1]) || String(id);
  }

  function getCart() {
    var cartUrl = window.Shopify && window.Shopify.routes && window.Shopify.routes.root
      ? window.Shopify.routes.root + 'cart.js'
      : '/cart.js';
    return fetch(cartUrl)
      .then(function (res) { return res.json(); })
      .catch(function () { return { items: [] }; });
  }

  function refreshCartSections() {
    var rootPath = window.Shopify && window.Shopify.routes && window.Shopify.routes.root
      ? window.Shopify.routes.root : '/';
    var sectionUrl = rootPath + '?sections=' + CART_SECTIONS.join(',');

    return Promise.all([
      fetch(sectionUrl).then(function (res) { return res.json(); }),
      fetch(rootPath + 'cart.js').then(function (res) { return res.json(); })
    ])
      .then(function (results) {
        var data = results[0];
        var cartData = results[1];
        var isEmpty = cartData.item_count === 0;

        // Forcefully toggle empty state classes for Dawn and similar themes
        var cartDrawerEls = document.querySelectorAll('cart-drawer, .drawer__inner, cart-items, cart-drawer-items');
        cartDrawerEls.forEach(function(el) {
          if (isEmpty) {
            el.classList.add('is-empty');
          } else {
            el.classList.remove('is-empty');
          }
        });

        // 1. Dawn Theme Native Support
        var cartDrawer = document.querySelector('cart-drawer');
        if (cartDrawer && typeof cartDrawer.renderContents === 'function') {
          // Pass the actual item_count to Dawn so it can toggle the 'is-empty' class correctly
          cartDrawer.renderContents({ sections: data, item_count: cartData.item_count });
          return;
        }

        // 2. Generic Theme Fallback
        var updated = 0;
        CART_SECTIONS.forEach(function (id) {
          if (!data[id]) return;
          
          var el = document.getElementById('shopify-section-' + id) 
                || document.querySelector('#' + id)
                || document.querySelector('.' + id)
                || document.querySelector('[data-section-id="' + id + '"]');
                
          if (el) {
            var temp = document.createElement('div');
            temp.innerHTML = data[id];
            
            // Only update inner elements to avoid overwriting outer Custom Elements
            var sectionNode = temp.querySelector('#shopify-section-' + id) || temp.firstElementChild;
            if (sectionNode && sectionNode.innerHTML) {
              el.innerHTML = sectionNode.innerHTML;
            } else {
              el.innerHTML = data[id];
            }
            updated++;
          }
        });

        document.documentElement.dispatchEvent(new CustomEvent('cart:updated', { bubbles: true }));
        document.documentElement.dispatchEvent(new CustomEvent('cart:change', { bubbles: true }));
        document.documentElement.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));

        if (updated === 0) {
          console.warn('[BXGY] Could not find cart sections to update via DOM. Falling back to reload.');
          window.location.reload();
        }
      })
      .catch(function (err) {
        console.error('[BXGY] Error refreshing sections', err);
        window.location.reload();
      });
  }

  function countQualifyingItems(cart, offer) {
    if (!offer || !cart.items || !cart.items.length) return 0;

    var applyTo = offer.applyTo || 'allProducts';

    // Gift variants must never count as qualifying items
    var giftVariantIds = ((offer.productGift && offer.productGift.giftProducts) || [])
      .map(function (g) { return normalizeId(g.variantId); });

    var selectedProductIds = (offer.products || [])
      .filter(function (p) { return !p.isExcluded; })
      .map(function (p) { return normalizeId(p.productId); });

    var excludedProductIds = (offer.products || [])
      .filter(function (p) { return p.isExcluded; })
      .map(function (p) { return normalizeId(p.productId); });

    var qty = 0;
    cart.items.forEach(function (item) {
      if (giftVariantIds.includes(normalizeId(item.variant_id))) return;

      var pid = normalizeId(item.product_id);
      var qualifies =
        applyTo === 'allProducts' ? true :
        applyTo === 'selectedProducts' ? selectedProductIds.includes(pid) :
        applyTo === 'excludeProducts' ? !excludedProductIds.includes(pid) : false;

      if (qualifies) qty += item.quantity;
    });
    return qty;
  }

  function autoAddGifts(offer, cart) {
    // Hard gate — never run concurrently
    if (isProcessing) return Promise.resolve();
    if (!offer || offer.giftMode !== 'PRODUCT_GIFT' || !offer.productGift) return Promise.resolve();

    var qualifyingQty = countQualifyingItems(cart, offer);
    var requiredQty   = offer.requiredQuantity || 1;
    var giftProducts  = offer.productGift.giftProducts || [];
    var giftQuantity  = offer.productGift.giftQuantity || 1;

    console.log('[BXGY] qualifying=' + qualifyingQty + ' required=' + requiredQty);

    // Build a map of gift variants currently in the cart
    var giftsInCart = {};
    cart.items.forEach(function (item) {
      var vid = normalizeId(item.variant_id);
      if (giftProducts.some(function (g) { return normalizeId(g.variantId) === vid; })) {
        giftsInCart[vid] = (giftsInCart[vid] || 0) + item.quantity;
      }
    });

    // ── REMOVE ────────────────────────────────────────────────────────────
    if (qualifyingQty < requiredQty) {
      var removeUpdates = {};
      cart.items.forEach(function (item) {
        if (giftsInCart[normalizeId(item.variant_id)] !== undefined) {
          removeUpdates[item.key] = 0;
        }
      });
      if (!Object.keys(removeUpdates).length) return Promise.resolve();

      console.log('[BXGY] Removing gifts.');
      isProcessing = true;
      return fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ updates: removeUpdates })
      })
        .then(function () {
          isProcessing = false;
          return refreshCartSections();
        })
        .catch(function (err) {
          isProcessing = false;
          console.error('[BXGY] Remove failed:', err);
        });
    }

    // ── ADD: only what's missing ───────────────────────────────────────────
    var itemsToAdd = giftProducts
      .filter(function (g) {
        if (!g.variantId) return false;
        var vid = normalizeId(g.variantId);
        return (giftsInCart[vid] || 0) < giftQuantity;
      })
      .map(function (g) {
        var vid = normalizeId(g.variantId);
        return {
          id: parseInt(vid, 10),
          quantity: giftQuantity - (giftsInCart[vid] || 0)
        };
      });

    if (!itemsToAdd.length) {
      console.log('[BXGY] Gift already in cart — nothing to do.');
      return Promise.resolve();
    }

    console.log('[BXGY] Adding gifts:', JSON.stringify(itemsToAdd));
    isProcessing = true;

    return fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: itemsToAdd })
    })
      .then(function (res) { return res.json(); })
      .then(function (data) {
        if (data.status && data.status !== 200) throw new Error(data.description || 'Add failed');
        isProcessing = false;
        console.log('[BXGY] Gift added.');
        return refreshCartSections();
        // ← intentionally NOT calling autoAddGifts again here
      })
      .catch(function (err) {
        isProcessing = false;
        console.error('[BXGY] Add failed:', err);
      });
  }

  // ── Debounced handler called by all event sources ─────────────────────────
  function scheduleCheck() {
    if (isProcessing) return;   // already doing something, skip
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(function () {
      if (isProcessing) return;
      getCart().then(function (cart) {
        autoAddGifts(currentOffer, cart);
      });
    }, 500);
  }

  // ── Event listeners and interceptors ──────────────────────────
  function attachCartListeners() {
    // 1. Shopify's own cart events (works in Dawn and most modern themes)
    document.addEventListener('cart:updated', scheduleCheck);
    document.addEventListener('cart:refresh', scheduleCheck);
    document.addEventListener('Cart:afterUpdateQuantity', scheduleCheck);
    document.addEventListener('cart.requestComplete', scheduleCheck);

    // 2. Global fetch interceptor (catches all AJAX cart updates)
    var originalFetch = window.fetch;
    window.fetch = function () {
      var url = arguments[0];
      var p = originalFetch.apply(this, arguments);
      if (typeof url === 'string' && url.indexOf('/cart/') !== -1 && !isProcessing) {
        // Wait for the theme's fetch to finish, then schedule our check
        p.then(function(res) {
          if (res.ok) setTimeout(scheduleCheck, 400);
          return res;
        }).catch(function() {});
      }
      return p;
    };

    // 3. XHR interceptor (for older themes)
    var originalXhrOpen = window.XMLHttpRequest.prototype.open;
    window.XMLHttpRequest.prototype.open = function(method, url) {
      if (typeof url === 'string' && url.indexOf('/cart/') !== -1 && !isProcessing) {
        this.addEventListener('load', function() {
          setTimeout(scheduleCheck, 400);
        });
      }
      return originalXhrOpen.apply(this, arguments);
    };

    // 4. Watch the add-to-cart form submit button directly as fallback
    document.addEventListener('submit', function (e) {
      var form = e.target;
      if (form && form.action && form.action.indexOf('/cart/add') !== -1) {
        setTimeout(scheduleCheck, 800);
      }
    }, true);

    // 5. Quantity input changes on the cart page (/cart)
    document.addEventListener('change', function (e) {
      var el = e.target;
      if (
        el.tagName === 'INPUT' &&
        (el.name === 'updates[]' || el.getAttribute('data-quantity-input') !== null)
      ) {
        setTimeout(scheduleCheck, 800);
      }
    });
  }

  // ── Render widget ─────────────────────────────────────────────────────────

  function fetchAndRender() {
    fetch('/apps/quantity-break?type=bxgy&productId=' + productId)
      .then(function (res) { return res.json(); })
      .then(function (data) {
        if (!data.offers || !data.offers.length) return;

        // Keep the first offer as primary for auto-add logic for now
        currentOffer = data.offers[0];

        root.innerHTML = ''; // Clear securely

        data.offers.forEach(function (offer) {
          var isProductGift = !!offer.productGift;
          var sectionLabel  = isProductGift ? '🎁 Free Gift Offer' : '🚚 Shipping Offer';
          var badgeText = '', badgeBg = '#dcfce7', badgeColor = '#15803d';

          if (isProductGift) {
            var pg = offer.productGift;
            badgeText = pg.discountType === 'free'      ? 'Free Gift'
                      : pg.discountType === 'percentage' ? pg.discountValue + '% OFF Gift'
                      : 'Gift at Fixed Price';
          }

          var requirementText = 'Buy ' + offer.requiredQuantity
            + ' qualifying item' + (offer.requiredQuantity > 1 ? 's' : '') + ' to unlock';

          var giftProducts = isProductGift && offer.productGift.giftProducts
            ? offer.productGift.giftProducts : [];

          // Create wrapper
          var wrapper = document.createElement('div');
          wrapper.style.marginBottom = '16px';

          var labelEl = document.createElement('div');
          labelEl.style.cssText = 'font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#6b7280;margin-bottom:6px;';
          labelEl.textContent = sectionLabel;
          wrapper.appendChild(labelEl);

          var card = document.createElement('div');
          card.style.cssText = 'border:1.5px solid #e5e7eb;border-radius:10px;padding:14px 16px;background:#fff;';

          var header = document.createElement('div');
          header.style.cssText = 'display:flex;align-items:center;justify-content:space-between;gap:8px;';

          var titleEl = document.createElement('div');
          titleEl.style.cssText = 'font-size:14px;font-weight:600;color:#111827;';
          titleEl.textContent = offer.discountTitle || offer.title;

          var badgeEl = document.createElement('div');
          badgeEl.style.cssText = 'background:' + badgeBg + ';color:' + badgeColor + ';font-size:12px;font-weight:700;padding:4px 10px;border-radius:20px;white-space:nowrap;';
          badgeEl.textContent = badgeText;

          header.appendChild(titleEl);
          header.appendChild(badgeEl);
          card.appendChild(header);

          var reqEl = document.createElement('div');
          reqEl.style.cssText = 'font-size:12px;color:#9ca3af;margin-top:5px;';
          reqEl.textContent = requirementText;
          card.appendChild(reqEl);

          giftProducts.forEach(function (g) {
            var giftLabel = offer.productGift.discountType === 'free'      ? 'FREE'
                          : offer.productGift.discountType === 'percentage' ? offer.productGift.discountValue + '% OFF'
                          : 'Fixed price';
            
            var row = document.createElement('div');
            row.style.cssText = 'display:flex;align-items:center;justify-content:space-between;font-size:13px;color:#374151;margin-top:6px;gap:8px;';

            var left = document.createElement('span');
            left.style.cssText = 'display:flex;align-items:center;gap:5px;';
            var check = document.createElement('span');
            check.style.cssText = 'color:#15803d;font-weight:700;';
            check.textContent = '✓';
            var gTitle = document.createElement('span');
            gTitle.textContent = g.title;
            left.appendChild(check);
            left.appendChild(gTitle);

            var right = document.createElement('span');
            right.style.cssText = 'font-size:11px;font-weight:700;background:#dcfce7;color:#15803d;padding:2px 7px;border-radius:12px;';
            right.textContent = giftLabel;

            row.appendChild(left);
            row.appendChild(right);
            card.appendChild(row);
          });

          if (isProductGift) {
            var msg = document.createElement('div');
            msg.style.cssText = 'font-size:12px;color:#6b7280;margin-top:10px;text-align:center;font-style:italic;';
            msg.textContent = 'Gift will be added automatically when you qualify';
            card.appendChild(msg);
          }

          wrapper.appendChild(card);
          root.appendChild(wrapper);
        });

        root.style.display = 'block';

        // Initial check on page load
        getCart().then(function (cart) { 
          data.offers.forEach(function(o) { autoAddGifts(o, cart); });
        });
      })
      .catch(function (err) {
        console.error('[BXGY] Error fetching offers:', err);
      });
  }

  function mountWidget() {
    var form = document.querySelector('form[action*="/cart/add"]');
    if (!form) return;

    var qtyWrap = form.querySelector('quantity-input')
      || form.querySelector('[class*="quantity"]')
      || (form.querySelector('input[name="quantity"]')
          && form.querySelector('input[name="quantity"]').parentElement);

    qtyWrap ? qtyWrap.after(root) : form.prepend(root);
    fetchAndRender();
  }

  function boot() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        mountWidget();
        attachCartListeners();
      });
    } else {
      mountWidget();
      attachCartListeners();
    }

    var observer = new MutationObserver(function () {
      if (document.querySelector('form[action*="/cart/add"]')) {
        observer.disconnect();
        mountWidget();
      }
    });
    observer.observe(document.body, { childList: true, subtree: true });
  }

  boot();
})();
</script>

{% schema %}
{
  "name": "BXGY Offers",
  "target": "body",
  "settings": []
}
{% endschema %}
